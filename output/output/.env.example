# Google OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twitter API — shared consumer keys (required)
CONSUMER_KEY=
CONSUMER_KEY_SECRET=

# Twitter API — legacy single-user tokens (optional, for backward compat)
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=

# Fernet encryption key for per-user Twitter tokens (required)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_FERNET_KEY=

# Claude API (required for drafting)
ANTHROPIC_API_KEY=

# Session/auth (required)
AUTH_SECRET_KEY=generate-a-random-secret-here

# Admin emails (comma-separated, auto-promoted on login)
ADMIN_EMAILS=admin@example.com

# Email alerts (optional)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
ALERT_RECIPIENT_EMAIL=

# Tuning (optional)
HOT_TWEET_THRESHOLD=50000
COOLDOWN_DAYS=7
DB_PATH=data/gstack_replies.db
ENVIRONMENT=development
