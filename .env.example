# Pattaya Email Configuration
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# Gmail App Password setup (required for Gmail SMTP):
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already on)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select "Mail" and your device, then Generate
#   5. Copy the 16-character password (no spaces) below
#
# The .env file is gitignored — your credentials stay local.

PATTAYA_SMTP_USER=your-email@gmail.com
PATTAYA_SMTP_PASS=your-16-char-app-password
