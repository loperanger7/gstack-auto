# gstack-auto-as-a-service configuration
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# The .env file is gitignored — your credentials stay local.

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API key for office hours chat
ANTHROPIC_API_KEY=

# First admin — this email gets auto-approved + admin on first Google login
ADMIN_EMAIL=

# Public URL (for build token callbacks)
BASE_URL=http://127.0.0.1:5000

# Daily token spend ceiling (default: 500000)
DAILY_TOKEN_CEILING=500000

# Rate limits
MAX_SESSIONS_PER_DAY=3
MAX_MESSAGES_PER_SESSION=100

# SMTP for build completion notifications (optional)
# Gmail App Password setup:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Generate and copy the 16-character password
PATTAYA_SMTP_HOST=smtp.gmail.com
PATTAYA_SMTP_PORT=587
PATTAYA_SMTP_USER=
PATTAYA_SMTP_PASS=
NOTIFY_FROM=
